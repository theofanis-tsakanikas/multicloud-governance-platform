{
  "name": "Multi-Cloud Governance Platform (offline copilot)",
  "//": "A zero-cloud dev environment for the governance copilot. Everything under scripts/, schema/, policy/ and the domain JSON runs here with no AWS/Azure/GCP credentials. After it builds, run `make demo`.",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers-contrib/features/conftest:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {}
  },
  "postCreateCommand": "pip install --user -r requirements-dev.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "hashicorp.terraform",
        "tsandall.opa"
      ],
      "settings": {
        "python.testing.pytestEnabled": true,
        "[python]": { "editor.defaultFormatter": "charliermarsh.ruff" }
      }
    }
  }
}
