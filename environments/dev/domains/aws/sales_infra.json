{
  "cloud": "AWS",
  "domain": "sales",
  "managed_storage_root": "databricks-project/sales/managed-zone/",
  "external_locations": [
    {"location_name": "loc_sales_raw", "path": "databricks-project/sales/raw-zone/"},
    {"location_name": "loc_sales_managed", "path": "databricks-project/sales/managed-zone/"},
    {"location_name": "loc_sales_gold", "path": "databricks-project/sales/gold-zone/"}
  ],
  "catalogs": [
    {
      "catalog_name": "sales_aws",
      "type": "MANAGED",
      "owner": "data_engineers",
      "storage_root": "databricks-project/sales/managed-zone/",
      "schemas": [
        {
          "schema_name": "bronze",
          "classification": "confidential",
          "volumes": [{
            "volume_name": "sales_landing_zone",
            "location_path": "databricks-project/sales/raw-zone/",
            "volume_path": "landing/",
            "volume_type": "EXTERNAL"
          }]
        },
        {"schema_name": "silver", "classification": "confidential"},
        {"schema_name": "gold", "classification": "internal"}
      ]
    },
    {
      "catalog_name": "sales_rds_fed",
      "type": "FEDERATED",
      "owner": "data_engineers",
      "connection_name": "rds_postgres_conn",
      "database_name": "salesdb",
      "schemas": [
        { "schema_name": "crm", "classification": "pii" },
        { "schema_name": "orders", "classification": "confidential" }
      ]
    }
  ]
}