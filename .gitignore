# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
crash.log
override.tf
override.tf.json

# Terragrunt
.terragrunt-cache/

# Sensitive files — NEVER commit
*.pem
*.key
*.p12
terraform.tfvars
*.auto.tfvars
secrets.hcl
provider_key.json

# Python
__pycache__/
*.py[cod]
venv/
.venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
# Ignore per-user VS Code state, but keep the shared, repo-wide editor config
# (domain-JSON schema mapping + recommended extensions) so autocomplete works
# out of the box. A negation only works if the parent dir isn't itself ignored,
# hence `.vscode/*` rather than `.vscode/`.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp

# Generated pipeline data (Level B) — bulk warehouse is regenerated on demand;
# only the deterministic docs/governance/data_profile.json + dashboard are committed.
pipelines/data/

# 📓 Local notes / study material (PDFs, overview + concepts — local only)
notes/
# Generated reading doc for the maintainer — not part of the repo's published surface.
THE-GATE-explained.pdf

# === Pre-publish security baseline (added 2026-06-22) ===
PRE-PUBLISH.md
.env
*.pfx
*.tfvars

# Screen recordings / promo assets (large binaries — keep out of git)
#
# `promo/*` and not `promo/`: git does not descend into an ignored DIRECTORY, so a negation inside
# one never fires. Ignore the contents instead, and the plans below survive.
promo/*
# The plans are documents, not assets. They cite numbers that must stay in step with the repo, and
# they are worth reviewing in a diff.
!promo/*.md
