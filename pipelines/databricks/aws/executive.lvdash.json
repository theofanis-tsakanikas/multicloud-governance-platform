{
  "datasets": [
    {
      "name": "exec",
      "displayName": "executive",
      "queryLines": [
        "SELECT market, revenue, orders, marketing_roi, avg_lead_days,\n",
        "       below_reorder_pct, revenue_at_risk\n",
        "FROM sales_aws.gold.executive_cross_cloud ORDER BY revenue DESC"
      ]
    },
    {
      "name": "risk",
      "displayName": "risk_total",
      "queryLines": [
        "SELECT ROUND(SUM(revenue_at_risk),0) AS revenue_at_risk\n",
        "FROM sales_aws.gold.executive_cross_cloud"
      ]
    },
    {
      "name": "rejects",
      "displayName": "rejects",
      "queryLines": [
        "SELECT reason, rows FROM sales_aws.silver.sales_rejects ORDER BY rows DESC"
      ]
    }
  ],
  "pages": [
    {
      "name": "executive",
      "displayName": "Executive",
      "layout": [
        {
          "widget": {
            "name": "title",
            "textbox_spec": "# Multi-Cloud Executive View\nThree clouds fused by market \u2014 revenue (AWS) \u00b7 demand (GCP, Delta-shared) \u00b7 supply risk (Azure)."
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "c_risk",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "risk",
                  "fields": [
                    {
                      "name": "revenue_at_risk",
                      "expression": "`revenue_at_risk`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "revenue_at_risk",
                  "displayName": "Revenue at risk (EUR)"
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "b_rev",
            "queries": [
              {
                "name": "q",
                "query": {
                  "datasetName": "exec",
                  "fields": [
                    {
                      "name": "market",
                      "expression": "`market`"
                    },
                    {
                      "name": "revenue",
                      "expression": "`revenue`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "market",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Market"
                },
                "y": {
                  "fieldName": "revenue",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "Revenue"
                }
              }
            }
          },
          "position": {
            "x": 2,
            "y": 1,
            "width": 4,
            "height": 4
          }
        },
        {
          "widget": {
            "name": "b_roi",
