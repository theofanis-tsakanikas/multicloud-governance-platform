{
  "_comment": "Golden corpus for the access-policy analyzer. Each case is a minimal but COMPLETE domain (infra + grants) crafted to trip exactly one rule (or none). tests/test_golden_policy.py materializes each into a temp repo, runs run_analysis, and asserts: every rule in `expect_rules` is present, and the set of gating (unacknowledged HIGH) rules equals `expect_gating`. This turns the governance gate from 'code' into 'provably-correct code'.",
  "cases": [
    {
      "name": "public_principal_on_pii",
      "cloud": "AWS",
      "infra": {
        "cloud": "AWS", "domain": "g",
        "catalogs": [{"catalog_name": "c", "type": "MANAGED", "owner": "data_engineers", "schemas": [{"schema_name": "cust", "classification": "pii"}]}]
      },
      "grants": {
        "schema_grants": [{"schema": "c.cust", "grants": [{"principal": "account users", "privileges": ["SELECT"]}]}]
      },
      "expect_rules": ["PUBLIC_PRINCIPAL", "PII_BROAD_READ"],
      "expect_gating": ["PUBLIC_PRINCIPAL", "PII_BROAD_READ"]
    },
    {
